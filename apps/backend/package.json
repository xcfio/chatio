{
    "name": "backend",
    "version": "0.0.1",
    "type": "commonjs",
    "author": "xcfio",
    "license": "MIT",
    "bugs": {
        "email": "xcfio@proton.me",
        "url": "https://github.com/xcfio/template"
    },
    "scripts": {
        "build": "rolldown -c",
        "db": "drizzle-kit studio --port=4000",
        "dev": "tsx watch --include src/**/* --no-warnings --env-file-if-exists=.env src/index.ts",
        "docker:build": "docker build --tag api .",
        "docker:start": "docker run --detach --rm --publish 7200:7200 api",
        "fmt": "prettier --config=.prettierrc --write src",
        "fmt:test": "prettier --config=.prettierrc --check src",
        "gen": "drizzle-kit generate",
        "start": "tsx --env-file-if-exists=.env src/index.ts",
        "test": "tsc --noEmit"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/error": "^4.2.0",
        "@fastify/jwt": "^10.0.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/type-provider-typebox": "^6.1.0",
        "@repo/schema": "workspace:*",
        "@scalar/fastify-api-reference": "^1.57.5",
        "discord-api-types": "^0.38.47",
        "drizzle-orm": "1.0.0-rc.2",
        "fastify": "^5.8.5",
        "fastify-socket": "^5.1.4",
        "fastify-utils": "^0.0.1",
        "postgres": "^3.4.9",
        "snowtransfer": "^0.17.7",
        "typebox": "^1.1.38",
        "typescript": "^6.0.3",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.7.0",
        "pino-pretty": "^13.1.3",
        "rolldown": "1.0.0"
    }
}
